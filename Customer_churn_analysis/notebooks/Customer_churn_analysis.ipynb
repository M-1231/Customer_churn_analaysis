   "source": [
    "# Export summary as markdown for reports/documentation\nsummary_markdown = generate_executive_summary(df, output_format='markdown')\n\n# Option 1: Display in notebook\nfrom IPython.display import Markdown\ndisplay(Markdown(summary_markdown))\n\n# Option 2: Save to file\nwith open('Churn_Analysis_Executive_Summary.md', 'w') as f:\n    f.write(summary_markdown)\nprint(\"\\nExecutive summary saved to 'Churn_Analysis_Executive_Summary.md'\")\n\n# Option 3: Get summary as dictionary for programmatic use\nsummary_dict = generate_executive_summary(df, output_format='dict')\nprint(\"\\nSummary dictionary created for further analysis or API use\")\nprint(\"Keys available:\", list(summary_dict.keys()))"
   ]

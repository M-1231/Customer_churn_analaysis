   "source": [
    "def generate_executive_summary(df, output_format='text'):\n",
    "    \"\"\"\n",
    "    Generates an automated executive summary of customer churn analysis.\n",
    "    \n",
    "    Parameters:\n",
    "    -----------\n",
    "    df : pandas.DataFrame\n",
    "        The customer churn dataset\n",
    "    output_format : str\n",
    "        Format of output: 'text' for plain text, 'markdown' for markdown, 'dict' for dictionary\n",
    "    \n",
    "    Returns:\n",
    "    --------\n",
    "    str or dict : Executive summary in specified format\n",
    "    \"\"\"\n",
    "    \n",
    "    # ===== CALCULATE KEY METRICS =====\n",
    "    total_customers = len(df)\n",
    "    churned_customers = len(df[df['Churn'] == 'Yes'])\n",
    "    retained_customers = len(df[df['Churn'] == 'No'])\n",
    "    churn_rate = (churned_customers / total_customers) * 100\n",
    "    retention_rate = (retained_customers / total_customers) * 100\n",
    "    \n",
    "    # Revenue metrics\n",
    "    churned_revenue = df[df['Churn'] == 'Yes']['MonthlyCharges'].sum()\n",
    "    total_revenue = df['MonthlyCharges'].sum()\n",
    "    revenue_at_risk = (churned_revenue / total_revenue) * 100\n",
    "    \n",
    "    # Tenure analysis\n",
    "    avg_tenure_churned = df[df['Churn'] == 'Yes']['TenureMonths'].mean()\n",
    "    avg_tenure_retained = df[df['Churn'] == 'No']['TenureMonths'].mean()\n",
    "    \n",
    "    # Satisfaction analysis\n",
    "    avg_satisfaction_churned = df[df['Churn'] == 'Yes']['SatisfactionScore'].mean()\n",
    "    avg_satisfaction_retained = df[df['Churn'] == 'No']['SatisfactionScore'].mean()\n",
    "    \n",
    "    # Top churn reasons\n",
    "    churn_reasons = df[df['Churn'] == 'Yes']['ChurnReason'].value_counts().head(3)\n",
    "    \n",
    "    # Contract type analysis\n",
    "    contract_churn = pd.crosstab(df['ContractType'], df['Churn'], normalize='index') * 100\n",
    "    highest_risk_contract = contract_churn['Yes'].idxmax()\n",
    "    highest_risk_contract_rate = contract_churn.loc[highest_risk_contract, 'Yes']\n",
    "    \n",
    "    # Payment method analysis\n",
    "    payment_churn = pd.crosstab(df['PaymentMethod'], df['Churn'], normalize='index') * 100\n",
    "    highest_risk_payment = payment_churn['Yes'].idxmax()\n",
    "    highest_risk_payment_rate = payment_churn.loc[highest_risk_payment, 'Yes']\n",
    "    \n",
    "    # Support tickets analysis\n",
    "    avg_support_tickets_churned = df[df['Churn'] == 'Yes']['NumSupportTickets'].mean()\n",
    "    avg_support_tickets_retained = df[df['Churn'] == 'No']['NumSupportTickets'].mean()\n",
    "    \n",
    "    # Late payments analysis\n",
    "    avg_late_payments_churned = df[df['Churn'] == 'Yes']['LatePaymentsLast6M'].mean()\n",
    "    avg_late_payments_retained = df[df['Churn'] == 'No']['LatePaymentsLast6M'].mean()\n",
    "    \n",
    "    # High-risk segment (Month-to-month + Electronic check)\n",
    "    high_risk = df[(df['ContractType'] == 'Month-to-month') & \n",
    "                   (df['PaymentMethod'] == 'Electronic check')]\n",
    "    high_risk_churn_rate = (len(high_risk[high_risk['Churn'] == 'Yes']) / len(high_risk)) * 100 if len(high_risk) > 0 else 0\n",
    "    \n",
    "    # Create summary dictionary\n",
    "    summary = {\n",
    "        'overview': {\n",
    "            'total_customers': total_customers,\n",
    "            'churned_customers': churned_customers,\n",
    "            'retained_customers': retained_customers,\n",
    "            'churn_rate': round(churn_rate, 2),\n",
    "            'retention_rate': round(retention_rate, 2)\n",
    "        },\n",
    "        'revenue_impact': {\n",
    "            'monthly_revenue_at_risk': round(churned_revenue, 2),\n",
    "            'total_monthly_revenue': round(total_revenue, 2),\n",
    "            'revenue_risk_percentage': round(revenue_at_risk, 2)\n",
    "        },\n",
    "        'customer_behavior': {\n",
    "            'avg_tenure_churned_months': round(avg_tenure_churned, 2),\n",
    "            'avg_tenure_retained_months': round(avg_tenure_retained, 2),\n",
    "            'avg_satisfaction_churned': round(avg_satisfaction_churned, 2),\n",
    "            'avg_satisfaction_retained': round(avg_satisfaction_retained, 2),\n",
    "            'avg_support_tickets_churned': round(avg_support_tickets_churned, 2),\n",
    "            'avg_support_tickets_retained': round(avg_support_tickets_retained, 2),\n",
    "            'avg_late_payments_churned': round(avg_late_payments_churned, 2),\n",
    "            'avg_late_payments_retained': round(avg_late_payments_retained, 2)\n",
    "        },\n",
    "        'risk_factors': {\n",
    "            'highest_risk_contract': highest_risk_contract,\n",
    "            'highest_risk_contract_churn_rate': round(highest_risk_contract_rate, 2),\n",
    "            'highest_risk_payment_method': highest_risk_payment,\n",
    "            'highest_risk_payment_churn_rate': round(highest_risk_payment_rate, 2),\n",
    "            'high_risk_segment_churn_rate': round(high_risk_churn_rate, 2)\n",
    "        },\n",
    "        'top_churn_reasons': churn_reasons.to_dict()\n",
    "    }\n",
    "    \n",
    "    # Generate output based on format\n",
    "    if output_format == 'dict':\n",
    "        return summary\n",
    "    \n",
    "    elif output_format == 'markdown':\n",
    "        md_text = f\"\"\"\n# Customer Churn Analysis - Executive Summary\n\n## Overview\n- **Total Customers**: {total_customers:,}\n- **Churned Customers**: {churned_customers:,} ({churn_rate:.2f}%)\n- **Retained Customers**: {retained_customers:,} ({retention_rate:.2f}%)\n\n## Revenue Impact\n- **Monthly Revenue at Risk**: ${churned_revenue:,.2f}\n- **Total Monthly Revenue**: ${total_revenue:,.2f}\n- **Revenue Risk Percentage**: {revenue_at_risk:.2f}%\n\n## Customer Behavior Insights\n\n### Tenure\n- Churned customers averaged **{avg_tenure_churned:.2f} months** (vs {avg_tenure_retained:.2f} months for retained)\n- Early-stage customers are at higher churn risk\n\n### Satisfaction\n- Churned customers: **{avg_satisfaction_churned:.2f}/5** satisfaction score\n- Retained customers: **{avg_satisfaction_retained:.2f}/5** satisfaction score\n- **Gap: {round(avg_satisfaction_retained - avg_satisfaction_churned, 2)} points** - significant dissatisfaction driver\n\n### Support Engagement\n- Churned customers raised **{avg_support_tickets_churned:.2f} support tickets** on average\n- Retained customers raised **{avg_support_tickets_retained:.2f} support tickets** on average\n\n### Payment Behavior\n- Churned customers had **{avg_late_payments_churned:.2f} late payments** in the last 6 months\n- Retained customers had **{avg_late_payments_retained:.2f} late payments** in the last 6 months\n\n## Risk Factors & High-Risk Segments\n\n### Contract Type Risk\n- **Highest Risk**: {highest_risk_contract} contracts\n- **Churn Rate**: {highest_risk_contract_rate:.2f}%\n\n### Payment Method Risk\n- **Highest Risk**: {highest_risk_payment}\n- **Churn Rate**: {highest_risk_payment_rate:.2f}%\n\n### Critical Segment\n- **Month-to-Month + Electronic Check**: {high_risk_churn_rate:.2f}% churn rate\n- This segment requires immediate attention\n\n## Top Churn Reasons\n\"\"\"\n        for idx, (reason, count) in enumerate(churn_reasons.items(), 1):\n            percentage = (count / churned_customers) * 100\n            md_text += f\"\\n{idx}. **{reason}**: {count} customers ({percentage:.2f}%)\"\n        \n        md_text += \"\"\"\n\n## Key Recommendations\n\n1. **Improve Service Quality**: Poor service experience is the #1 churn reason (33%)\n2. **Contract Optimization**: Promote longer-term contracts instead of month-to-month\n3. **Payment Method**: Encourage more stable payment methods over electronic checks\n4. **Support Enhancement**: Increase support ticket quality and resolution speed\n5. **Early Intervention**: Focus on customers in their first 12 months\n6. **Satisfaction Focus**: Improve satisfaction scores, especially for at-risk segments\n\"\"\"\n        return md_text\n    \n    else:  # text format\n        text_summary = f\"\"\"\n{'='*80}\nCUSTOMER CHURN ANALYSIS - EXECUTIVE SUMMARY\n{'='*80}\n\nOVERVIEW\n{'-'*80}\nTotal Customers:                {total_customers:>10,}\nChurned Customers:              {churned_customers:>10,}  ({churn_rate:>6.2f}%)\nRetained Customers:             {retained_customers:>10,}  ({retention_rate:>6.2f}%)\n\nREVENUE IMPACT\n{'-'*80}\nMonthly Revenue at Risk:        ${churned_revenue:>15,.2f}\nTotal Monthly Revenue:          ${total_revenue:>15,.2f}\nRevenue Risk Percentage:        {revenue_at_risk:>16.2f}%\n\nCUSTOMER BEHAVIOR INSIGHTS\n{'-'*80}\nAverage Tenure (Churned):       {avg_tenure_churned:>16.2f} months\nAverage Tenure (Retained):      {avg_tenure_retained:>16.2f} months\n\nAverage Satisfaction (Churned): {avg_satisfaction_churned:>16.2f}/5\nAverage Satisfaction (Retained):{avg_satisfaction_retained:>16.2f}/5\nSatisfaction Gap:               {round(avg_satisfaction_retained - avg_satisfaction_churned, 2):>16.2f} points\n\nAverage Support Tickets (Churned): {avg_support_tickets_churned:>12.2f}\nAverage Support Tickets (Retained): {avg_support_tickets_retained:>12.2f}\n\nAverage Late Payments (Churned):    {avg_late_payments_churned:>12.2f}\nAverage Late Payments (Retained):   {avg_late_payments_retained:>12.2f}\n\nRISK FACTORS\n{'-'*80}\nHighest Risk Contract Type:     {highest_risk_contract:>20} ({highest_risk_contract_rate:.2f}% churn)\nHighest Risk Payment Method:    {highest_risk_payment:>20} ({highest_risk_payment_rate:.2f}% churn)\nHigh-Risk Segment Churn Rate:   {high_risk_churn_rate:>20.2f}%\n(Month-to-Month + Electronic Check)\n\nTOP 3 CHURN REASONS\n{'-'*80}\n\"\"\"\n        for idx, (reason, count) in enumerate(churn_reasons.items(), 1):\n            percentage = (count / churned_customers) * 100\n            text_summary += f\"{idx}. {reason:<30} {count:>6} customers ({percentage:>6.2f}%)\\n\"\n        \n        text_summary += f\"\"\"\n{'='*80}\nKEY RECOMMENDATIONS\n{'='*80}\n1. Improve Service Quality - Poor service experience accounts for 33% of churn\n2. Promote Longer-Term Contracts - Month-to-month has highest churn rates\n3. Enhance Payment Method Options - Electronic check users have high churn\n4. Focus on Early Tenure Customers - New customers at highest risk\n5. Increase Support Quality - Too many support issues is 2nd reason for churn\n6. Address Satisfaction Gaps - {round(avg_satisfaction_retained - avg_satisfaction_churned, 2)} point gap is critical\n{'='*80}\n\"\"\"\n        return text_summary\n\n# Generate and display the executive summary\nprint(generate_executive_summary(df, output_format='text'))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "export_summary",
